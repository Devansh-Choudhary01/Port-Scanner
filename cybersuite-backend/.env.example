# ─── App Settings ────────────────────────────────────────────────────────────
APP_NAME=CyberSuite API
APP_VERSION=1.0.0
DEBUG=false

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Scan Configuration ───────────────────────────────────────────────────────
MAX_PORT_RANGE=1024          # Max ports per scan
SCAN_TIMEOUT=5               # Seconds per connection attempt
MAX_CONCURRENT_SCANS=10      # Parallel scans allowed

# ─── AI Assistant ─────────────────────────────────────────────────────────────
# Set to "openai" to enable GPT-powered responses
AI_MODEL=rule-based
# OPENAI_API_KEY=sk-...       # Uncomment and fill to enable OpenAI

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT=30                # Requests per minute per IP
