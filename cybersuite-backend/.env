# ─── App Settings ────────────────────────────────────────────────────────────
APP_NAME=CyberSuite API
APP_VERSION=1.0.0
DEBUG=false

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# ─── Scan Configuration ───────────────────────────────────────────────────────
MAX_PORT_RANGE=5000          # Max ports per scan

SCAN_TIMEOUT=5               # Seconds per connection attempt
MAX_CONCURRENT_SCANS=10      # Parallel scans allowed

# ─── AI Assistant ─────────────────────────────────────────────────────────────
# Set to "openai" to enable GPT-powered responses
AI_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=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
GROQ_API_URL=https://api.groq.com/openai/v1


# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT=30                # Requests per minute per IP
